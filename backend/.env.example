# ===========================================
# Admin Login
# ===========================================
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ===========================================
# App Settings
# ===========================================
SECRET_KEY=change-this-secret-key-in-production-use-long-random-string
# Neon PostgreSQL — use SAME URL on PC (login-facebook.bat) and Render:
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# Local-only fallback (optional):
# DATABASE_URL=sqlite:///./marketplace_monitor.db
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===========================================
# SMTP — Backend only (NOT shown in dashboard)
# Gmail: enable 2FA, create App Password
# SMTP_USER = sender Gmail address
# SMTP_PASSWORD = 16-char App Password
# ===========================================
# SMTP — Gmail App Password. Works locally; on Render FREE tier SMTP is blocked (use PAID Render).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Marketplace Monitor
SMTP_USE_TLS=true

# Playwright — leave empty locally (visible browser). Render sets RENDER=true (headless).
# Set true only if you want headless monitoring on your PC too.
PLAYWRIGHT_HEADLESS=false
