# =========================
# Secrets (never commit)
# =========================
backend/.env
frontend/.env
frontend/.env.local
.env
.env.local

# =========================
# Python / Backend
# =========================
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local SQLite (legacy); production uses Neon in .env
backend/*.db
backend/**/*.db

# Playwright browsers (large; run install-chromium.bat after clone)
backend/playwright-browsers/

# Facebook session, browser profiles, runtime pid
backend/data/*
!backend/data/.gitkeep

# =========================
# Node / Frontend
# =========================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# IDE / OS
# =========================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
Desktop.ini

# Cursor local state
.cursor/
